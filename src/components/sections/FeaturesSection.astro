---
import { siteConfig } from "@/config/site"
import { Monitor, Share2, Globe, Target, Tv, Megaphone, DollarSign, Palette } from "@lucide/astro"

interface Feature { icon?: string; title: string; description: string }

interface Props {
  badge?: string
  title: string
  description?: string
  features: Feature[]
  columns?: 2 | 3 | 4
  variant?: "default" | "numbered"
}

const { badge, title, description, features, columns = 4, variant = "default" } = Astro.props

const getLocationText = (text: string) => text
  .replaceAll("{city}", siteConfig.location.city)
  .replaceAll("{state}", siteConfig.location.state)
  .replaceAll("{business}", siteConfig.business.name)

const processedTitle = getLocationText(title)
const processedDescription = description ? getLocationText(description) : undefined
const processedBadge = badge ? getLocationText(badge) : undefined

const gridCols: Record<number, string> = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-2 lg:grid-cols-3",
  4: "md:grid-cols-2 lg:grid-cols-4",
}

const iconComponents: Record<string, any> = {
  monitor: Monitor, share: Share2, globe: Globe, target: Target,
  tv: Tv, megaphone: Megaphone, dollar: DollarSign, palette: Palette,
}
---

<section class="features-sec">
  <div class="container mx-auto px-4 md:px-8">
    <div class="features-head animate-fade-up">
      {processedBadge && <span class="chip-label mb-6">{processedBadge}</span>}
      <h2 class="features-title">{processedTitle}</h2>
      {processedDescription && <p class="features-desc" set:html={processedDescription} />}
    </div>

    <div class={`grid gap-5 md:gap-6 ${gridCols[columns]}`}>
      {features.map((feature, i) => {
        const IconComponent = feature.icon ? iconComponents[feature.icon] : null
        const isNumbered = variant === "numbered"
        return (
          <article class={`feature-card animate-fade-up ${isNumbered ? 'feature-card--numbered' : ''}`} style={`animation-delay: ${i * 90}ms`}>
            {isNumbered && (
              <span class="feature-num">{String(i + 1).padStart(2, '0')}</span>
            )}
            {IconComponent && (
              <div class="feature-icon">
                <IconComponent class="w-5 h-5" />
              </div>
            )}
            <h3 class="feature-title">{getLocationText(feature.title)}</h3>
            <p class="feature-desc" set:html={getLocationText(feature.description)} />
          </article>
        )
      })}
    </div>
  </div>
</section>

<style>
  .features-sec {
    padding: 2rem 0 2.5rem;
    background: var(--bg-cream);
  }
  @media (min-width: 768px) { .features-sec { padding: 2.75rem 0 3.25rem; } }

  .features-head {
    max-width: 48rem;
    margin-bottom: 3rem;
  }
  .features-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 1rem 0 1rem;
  }
  .features-desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 38rem;
  }

  .feature-card {
    position: relative;
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: 16px;
    padding: 1.75rem 1.5rem 1.75rem;
    height: 100%;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    border-color: var(--terracotta);
    box-shadow: 0 20px 40px -20px rgba(26,26,26,0.15);
  }
  .feature-card--numbered { padding-top: 2.5rem; }

  .feature-num {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--terracotta);
    letter-spacing: 0.02em;
  }
  .feature-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--bg-cream);
    color: var(--terracotta);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .feature-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0 0 0.6rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .feature-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fade-up 0.7s cubic-bezier(.22,.8,.36,1) forwards;
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-up { animation: none; opacity: 1; }
    .feature-card:hover { transform: none; }
  }
</style>
