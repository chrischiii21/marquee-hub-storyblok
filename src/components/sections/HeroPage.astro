---
import { getLocationText } from "@/config/site"
import AnimateOnScroll from "@/components/AnimateOnScroll.astro"
import { ArrowUpRight } from "lucide-react"

interface Props {
  badge?: string
  title: string
  description?: string
  image?: string
  imageAlt?: string
  ctaText?: string
  ctaHref?: string
}

const { badge, title, description, image, imageAlt = "Hero image", ctaText, ctaHref = "/contact" } = Astro.props

const processedTitle = getLocationText(title)
const processedDescription = description ? getLocationText(description) : undefined
const processedBadge = badge ? getLocationText(badge) : undefined
---

<section class="page-hero">
  <div class="container mx-auto px-4 md:px-8">
    <AnimateOnScroll animation="fade-up">
      <div class={`page-hero__grid ${image ? "page-hero__grid--with-media" : "page-hero__grid--text-only"}`}>
        <div class="dark-card page-hero__panel">
          {processedBadge && <span class="chip-label chip-label--light mb-6">{processedBadge}</span>}
          <h1 class="page-hero__title">{processedTitle}</h1>
          {processedDescription && (
            <p class="page-hero__desc">{processedDescription}</p>
          )}
          {ctaText && (
            <a href={ctaHref} class="pill-btn pill-btn--terracotta mt-4 page-hero__cta">
              {ctaText}
              <span class="pill-arrow"><ArrowUpRight className="w-4 h-4" /></span>
            </a>
          )}
        </div>
        {image && (
          <div class="image-card page-hero__media">
            <img src={image} alt={imageAlt} width={1200} height={900} fetchpriority="high" decoding="async" />
          </div>
        )}
      </div>
    </AnimateOnScroll>
  </div>
</section>

<style>
  .page-hero {
    background: var(--bg-cream);
    padding: 2rem 0 3rem;
  }
  @media (min-width: 768px) { .page-hero { padding: 3rem 0 4.5rem; } }

  .page-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .page-hero__grid--with-media {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    }
    .page-hero__grid--text-only {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .page-hero__panel {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
    min-height: 320px;
  }
  @media (min-width: 768px) {
    .page-hero__panel { padding: 3.5rem 3rem; min-height: 420px; }
  }
  .page-hero__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    color: #fff !important;
    margin: 0.25rem 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .page-hero__desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 0.5rem;
    max-width: 36rem;
  }
  @media (min-width: 768px) {
    .page-hero__desc { font-size: 1.05rem; }
  }
  .page-hero__cta { align-self: flex-start; }

  .page-hero__media {
    position: relative;
    aspect-ratio: 16/11;
    min-height: 260px;
    overflow: hidden;
  }
  .page-hero__media::after { display: none; }
  .page-hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
