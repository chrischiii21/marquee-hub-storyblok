---
import { getLocationText } from "@/config/site"
import AnimateOnScroll from "@/components/AnimateOnScroll.astro"
import {
  Check, MapPin, Clock, Target, Zap, Globe, Palette, TrendingUp, Megaphone, Search,
  ChevronLeft, ChevronRight, ArrowUpRight
} from "lucide-react"
import { cn } from "@/lib/utils"

const iconMap: Record<string, any> = {
  check: Check, mappin: MapPin, clock: Clock, target: Target, zap: Zap,
  globe: Globe, palette: Palette, trending: TrendingUp, megaphone: Megaphone, google: Search,
}

interface Feature { text: string; icon?: string }
interface Slide { title: string; description: string }

interface Props {
  badge?: string
  title?: string
  description?: string
  secondaryDescription?: string
  slides?: Slide[]
  features?: (string | Feature)[]
  buttonText?: string
  buttonHref?: string
  image: string
  imageAlt?: string
  imagePosition?: "left" | "right"
  variant?: "simple" | "card" | "dark" | "gradient" | "minimal"
}

const {
  badge,
  title = "",
  description = "",
  secondaryDescription,
  slides,
  features,
  buttonText,
  buttonHref,
  image,
  imageAlt = "Editorial illustration",
  imagePosition = "right",
  variant = "simple",
} = Astro.props

const processedTitle = getLocationText(title)
const processedDescription = getLocationText(description)
const processedSecondaryDescription = secondaryDescription ? getLocationText(secondaryDescription) : undefined
const processedBadge = badge ? getLocationText(badge) : undefined

const hasSlides = slides && slides.length > 0

const useCenteredHeadline = false
---

<section class={`content-sec content-sec--${variant}`}>
  <div class="container mx-auto px-4 md:px-8">

    {variant === "dark" && (
      <AnimateOnScroll animation="fade-up">
        <div class="dark-card content-dark">
          <div class={cn("content-dark__grid", imagePosition === "left" ? "content-dark__grid--reverse" : "")}>
            <div class="content-dark__body">
              {processedBadge && <span class="chip-label chip-label--light mb-6">{processedBadge}</span>}
              <h2 class="content-dark__title">{processedTitle}</h2>
              <p class="content-dark__desc" set:html={processedDescription} />
              {processedSecondaryDescription && <p class="content-dark__desc content-dark__desc--sub" set:html={processedSecondaryDescription} />}
              {buttonText && buttonHref && (
                <a href={buttonHref} class="pill-btn pill-btn--light mt-4">
                  {buttonText}
                  <span class="pill-arrow"><ArrowUpRight className="w-4 h-4" /></span>
                </a>
              )}
            </div>
            <div class="content-dark__media image-card">
              <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
            </div>
          </div>
        </div>
      </AnimateOnScroll>
    )}

    {variant === "card" && (
      <AnimateOnScroll animation="fade-up">
        <div class={cn("content-card-row", imagePosition === "left" ? "content-card-row--reverse" : "")}>
          <div class="dark-card content-card-body">
            {processedBadge && <span class="chip-label chip-label--light mb-5">{processedBadge}</span>}
            <h2 class="content-card-title">{processedTitle}</h2>
            <p class="content-card-desc" set:html={processedDescription} />
            {processedSecondaryDescription && <p class="content-card-desc" set:html={processedSecondaryDescription} />}
            {features && features.length > 0 && (
              <ul class="content-feature-list">
                {features.map((feature) => {
                  const isObject = typeof feature === "object"
                  const featureText = isObject ? feature.text : feature
                  const iconName = isObject && feature.icon ? feature.icon : "check"
                  const Icon = iconMap[iconName] || Check
                  return (
                    <li class="content-feature-item">
                      <span class="content-feature-dot"><Icon className="w-3 h-3" /></span>
                      <span set:html={getLocationText(featureText)} />
                    </li>
                  )
                })}
              </ul>
            )}
            {buttonText && buttonHref && (
              <a href={buttonHref} class="pill-btn pill-btn--light mt-3">
                {buttonText}
                <span class="pill-arrow"><ArrowUpRight className="w-4 h-4" /></span>
              </a>
            )}
          </div>
          <div class="image-card content-card-media">
            <img src={image} alt={imageAlt} width={800} height={600} loading="lazy" decoding="async" />
          </div>
        </div>
      </AnimateOnScroll>
    )}

    {(variant === "simple" || variant === "gradient" || variant === "minimal") && (
      <div>
        {/* Centered editorial headline (no inline images) */}
        {!hasSlides && useCenteredHeadline && (
          <AnimateOnScroll animation="fade-up">
            <div class="editorial-headline">
              {processedBadge && <span class="chip-label mb-5">{processedBadge}</span>}
              <h2 class="editorial-title">{processedTitle}</h2>
              {processedDescription && (
                <p class="editorial-desc" set:html={processedDescription} />
              )}
              {buttonText && buttonHref && (
                <a href={buttonHref} class="pill-btn mt-6">
                  {buttonText}
                  <span class="pill-arrow"><ArrowUpRight className="w-4 h-4" /></span>
                </a>
              )}
            </div>
          </AnimateOnScroll>
        )}

        {(!useCenteredHeadline || hasSlides) && (
          <div class={cn("content-split", imagePosition === "left" && "content-split--reverse")}>
            <AnimateOnScroll animation={imagePosition === "left" ? "fade-left" : "fade-right"}>
              <div x-data={hasSlides ? `{ currentSlide: 0, slideCount: ${slides?.length || 0} }` : "{}"}>
                {processedBadge && <span class="chip-label mb-6">{processedBadge}</span>}
                {hasSlides ? (
                  <>
                    <div class="relative min-h-[200px] mt-4">
                      {slides?.map((slide, index) => (
                        <div
                          x-show={`currentSlide === ${index}`}
                          x-transition:enter="transition ease-out duration-500"
                          x-transition:enter-start="opacity-0 translate-y-4"
                          x-transition:enter-end="opacity-100 translate-y-0"
                          x-transition:leave="transition ease-in duration-300"
                          x-transition:leave-start="opacity-100"
                          x-transition:leave-end="opacity-0 absolute inset-0"
                          class={index === 0 ? "" : "absolute inset-0"}
                        >
                          <h2 class="split-title">{getLocationText(slide.title)}</h2>
                          <p class="split-desc">{getLocationText(slide.description)}</p>
                        </div>
                      ))}
                    </div>
                    <div class="flex items-center gap-4 mt-8">
                      <div class="flex gap-2">
                        <button @click="currentSlide = (currentSlide - 1 + slideCount) % slideCount" class="slide-btn"><ChevronLeft className="w-5 h-5" /></button>
                        <button @click="currentSlide = (currentSlide + 1) % slideCount" class="slide-btn"><ChevronRight className="w-5 h-5" /></button>
                      </div>
                      <div class="flex gap-2">
                        {slides?.map((_, index) => (
                          <button
                            @click={`currentSlide = ${index}`}
                            :class={`currentSlide === ${index} ? 'slide-dot slide-dot--active' : 'slide-dot'`}
                            class="slide-dot"
                          />
                        ))}
                      </div>
                    </div>
                  </>
                ) : (
                  <>
                    <h2 class="split-title">{processedTitle}</h2>
                    <p class="split-desc" set:html={processedDescription} />
                    {processedSecondaryDescription && <p class="split-desc split-desc--sub">{processedSecondaryDescription}</p>}
                  </>
                )}

                {features && features.length > 0 && (
                  <ul class="content-feature-list content-feature-list--light">
                    {features.map((feature) => {
                      const isObject = typeof feature === "object"
                      const featureText = isObject ? feature.text : feature
                      const iconName = isObject && feature.icon ? feature.icon : "check"
                      const Icon = iconMap[iconName] || Check
                      return (
                        <li class="content-feature-item">
                          <span class="content-feature-dot"><Icon className="w-3 h-3" /></span>
                          <span set:html={getLocationText(featureText)} />
                        </li>
                      )
                    })}
                  </ul>
                )}

                {buttonText && buttonHref && (
                  <a href={buttonHref} class="pill-btn mt-6">
                    {buttonText}
                    <span class="pill-arrow"><ArrowUpRight className="w-4 h-4" /></span>
                  </a>
                )}
              </div>
            </AnimateOnScroll>

            <AnimateOnScroll animation={imagePosition === "left" ? "fade-right" : "fade-left"}>
              <div class="image-card split-image">
                <img src={image} alt={imageAlt} width={800} height={600} loading="lazy" decoding="async" />
              </div>
            </AnimateOnScroll>
          </div>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .content-sec {
    padding: 2rem 0;
    background: var(--bg-cream);
  }
  @media (min-width: 768px) { .content-sec { padding: 2.75rem 0; } }

  /* ==== Dark variant ==== */
  .content-dark { padding: 0; overflow: hidden; }
  .content-dark__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 500px;
  }
  @media (min-width: 900px) {
    .content-dark__grid { grid-template-columns: 1.2fr 1fr; }
  }
  .content-dark__grid--reverse > .content-dark__body { order: 2; }
  .content-dark__grid--reverse > .content-dark__media { order: 1; }

  .content-dark__body {
    padding: 2.5rem;
    display: flex; flex-direction: column; justify-content: center; gap: 1rem;
  }
  @media (min-width: 768px) { .content-dark__body { padding: 4rem; } }
  .content-dark__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    color: #fff !important;
    margin: 0 0 0.5rem;
    letter-spacing: -0.015em;
  }
  .content-dark__desc {
    color: rgba(255,255,255,0.72);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }
  .content-dark__desc--sub { color: rgba(255,255,255,0.55); }
  .content-dark__media {
    position: relative;
    min-height: 300px;
    border-radius: 0;
  }
  .content-dark__media::after { display: none; }
  .content-dark__media img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }

  /* ==== Card variant (side-by-side bento row) ==== */
  .content-card-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .content-card-row {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: 1.25rem;
    }
    .content-card-row--reverse { direction: rtl; }
    .content-card-row--reverse > * { direction: ltr; }
  }
  .content-card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0.75rem;
  }
  @media (min-width: 768px) { .content-card-body { padding: 2.75rem; } }
  .content-card-body > .chip-label { align-self: flex-start; }
  .content-card-body > .pill-btn { align-self: flex-start; }
  .content-card-media {
    position: relative;
    aspect-ratio: 16/11;
    min-height: 320px;
    overflow: hidden;
  }
  .content-card-media::after { display: none; }
  .content-card-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .content-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 2.2vw, 1.9rem);
    line-height: 1.2;
    color: #fff !important;
    margin: 0 0 0.75rem;
    letter-spacing: -0.015em;
  }
  .content-card-desc {
    color: rgba(255,255,255,0.72);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  /* ==== Editorial inline-image headline ==== */
  .editorial-headline {
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
    padding: 2rem 0 3rem;
  }
  .editorial-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 4.2vw, 3rem);
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 1.5rem;
    letter-spacing: -0.015em;
  }
  .editorial-line {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .editorial-inline-img {
    display: inline-block;
    width: clamp(80px, 10vw, 120px);
    height: clamp(32px, 4.5vw, 52px);
    border-radius: 999px;
    overflow: hidden;
    vertical-align: middle;
    margin: 0 0.25rem;
    flex-shrink: 0;
  }
  .editorial-inline-img--sm {
    width: clamp(70px, 9vw, 110px);
    height: clamp(28px, 4vw, 46px);
  }
  .editorial-inline-img img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .editorial-desc {
    max-width: 36rem;
    margin: 1.5rem auto 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--muted);
  }

  /* ==== Split layout ==== */
  .content-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .content-split {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .content-split--reverse > :global(:first-child) { order: 2; }
  }
  .split-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--ink);
    margin: 1rem 0 1rem;
    letter-spacing: -0.015em;
  }
  .split-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 0 1rem;
  }
  .split-desc--sub { font-size: 0.9rem; }
  .split-image {
    aspect-ratio: 16/9;
    max-height: 360px;
  }
  .split-image::after { display: none; }
  .split-image img { width: 100%; height: 100%; object-fit: cover; }

  /* ==== Slide navigation ==== */
  .slide-btn {
    width: 42px; height: 42px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--hairline);
    color: var(--ink);
    display: inline-flex; align-items: center; justify-content: center;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .slide-btn:hover { background: var(--ink); color: #fff; border-color: var(--ink); }
  .slide-dot {
    height: 6px; width: 6px;
    border-radius: 999px;
    background: var(--hairline);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .slide-dot--active { background: var(--terracotta); width: 24px; }

  /* ==== Feature list ==== */
  .content-feature-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0;
    display: grid;
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .content-feature-list { grid-template-columns: 1fr 1fr; gap: 0.5rem 1.25rem; }
  }
  .content-feature-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.82);
  }
  .content-feature-list--light .content-feature-item { color: var(--ink-soft); }
  .content-feature-dot {
    width: 22px; height: 22px;
    border-radius: 999px;
    background: var(--terracotta);
    color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
</style>
