---
import BaseLayout from "@/layouts/BaseLayout.astro"
import HeroHomeStatic from "@/components/sections/HeroHomeStatic.astro"
import HeroPage from "@/components/sections/HeroPage.astro"
import FeaturesSection from "@/components/sections/FeaturesSection.astro"
import ContentSection from "@/components/sections/ContentSection.astro"
import CTASection from "@/components/sections/CTASection.astro"
import FAQSection from "@/components/sections/FAQSection.astro"
import LocationsSection from "@/components/sections/LocationsSection.astro"
import ValueCardsSection from "@/components/sections/ValueCardsSection.astro"
import ContactSection from "@/components/sections/ContactSection.astro"
import { siteConfig, getLocationText } from "@/config/site"
import { sanityClient } from "sanity:client"
import { urlFor } from "@/lib/sanityImage"

export const prerender = true

function stripHtml(input: string = ""): string {
  return input.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").trim()
}

function buildPageSchemas(pageData: any, slug: string | undefined, pathname: string) {
  const sections: any[] = pageData.sections || []
  const url = new URL(pathname, siteConfig.seo.siteUrl).href
  const isHomepage = !slug
  const isLocationPage = slug?.startsWith("locations/")
  const isContactPage = slug === "contact"
  const isAboutPage = slug === "about"
  const pageTitle = getLocationText(pageData.title || "")
  const pageDescription = getLocationText(pageData.description || siteConfig.seo.defaultDescription)

  const schemas: Record<string, any>[] = []

  // 1. WebPage (or specialized variant) for every page
  let webPageType: string = "WebPage"
  if (isContactPage) webPageType = "ContactPage"
  else if (isAboutPage) webPageType = "AboutPage"
  else if (pageData.legalSections) webPageType = "WebPage"

  schemas.push({
    "@context": "https://schema.org",
    "@type": webPageType,
    name: pageTitle,
    description: pageDescription,
    url,
    inLanguage: "en-US",
    isPartOf: {
      "@type": "WebSite",
      name: siteConfig.seo.siteName,
      url: siteConfig.seo.siteUrl,
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.business.name,
      logo: {
        "@type": "ImageObject",
        url: new URL(siteConfig.logo.src, siteConfig.seo.siteUrl).href,
      },
    },
  })

  // 2. BreadcrumbList for non-homepage pages
  if (!isHomepage && slug) {
    const parts = slug.split("/")
    const items: any[] = [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteConfig.seo.siteUrl + "/",
      },
    ]
    let cumulative = ""
    parts.forEach((part, idx) => {
      cumulative += "/" + part
      const label = part
        .replace(/-/g, " ")
        .replace(/\b\w/g, (c) => c.toUpperCase())
      items.push({
        "@type": "ListItem",
        position: idx + 2,
        name: label,
        item: new URL(cumulative, siteConfig.seo.siteUrl).href,
      })
    })
    schemas.push({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: items,
    })
  }

  // 3. FAQPage if any faq section has at least one Q&A
  const faqSection = sections.find((s) => s.type === "faq")
  if (faqSection && Array.isArray(faqSection.faqs) && faqSection.faqs.length > 0) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqSection.faqs.map((f: any) => ({
        "@type": "Question",
        name: stripHtml(getLocationText(f.question || "")),
        acceptedAnswer: {
          "@type": "Answer",
          text: stripHtml(getLocationText(f.answer || "")),
        },
      })),
    })
  }

  // 4. Service schema for service/solution pages (any page that isn't home/contact/about/legal/location/locations index)
  const isServicePage =
    !isHomepage &&
    !isContactPage &&
    !isAboutPage &&
    !isLocationPage &&
    slug !== "locations" &&
    !pageData.legalSections
  if (isServicePage) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "Service",
      name: pageTitle,
      description: pageDescription,
      url,
      provider: {
        "@type": "LocalBusiness",
        name: siteConfig.business.name,
        telephone: siteConfig.contact.phone,
        address: {
          "@type": "PostalAddress",
          streetAddress: siteConfig.location.address,
          addressLocality: siteConfig.location.city,
          addressRegion: siteConfig.location.state,
          addressCountry: "US",
        },
      },
      areaServed: {
        "@type": "City",
        name: siteConfig.location.city,
      },
    })
  }

  // 5. Location pages get a dedicated LocalBusiness with the served city
  if (isLocationPage && pageData.city) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      name: `${siteConfig.business.name} — ${pageData.city}`,
      description: pageDescription,
      url,
      telephone: siteConfig.contact.phone,
      email: siteConfig.contact.email,
      image: siteConfig.seo.ogImage,
      address: {
        "@type": "PostalAddress",
        addressLocality: pageData.city,
        addressRegion: siteConfig.location.state,
        addressCountry: "US",
      },
      areaServed: {
        "@type": "City",
        name: pageData.city,
      },
      priceRange: "$$",
    })
  }

  // 6. ContactPage gets a ContactPoint as well
  if (isContactPage) {
    schemas.push({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: siteConfig.business.name,
      url: siteConfig.seo.siteUrl,
      contactPoint: {
        "@type": "ContactPoint",
        telephone: siteConfig.contact.phone,
        email: siteConfig.contact.email,
        contactType: "customer service",
        areaServed: "US",
        availableLanguage: ["English"],
      },
    })
  }

  return schemas
}

// NOTE: Astro extracts `getStaticPaths` into its own module context at build
// time, so module-scope helpers declared in this frontmatter (other than
// imports) are NOT reachable from inside it. Everything the function needs
// is therefore defined inline, inside `getStaticPaths` itself.
export async function getStaticPaths() {
  // Maps Sanity's section object `_type` back to the plain `type` string the
  // section components below switch on.
  const sectionTypeMap: Record<string, string> = {
    heroSection: 'hero',
    featuresSection: 'features',
    contentSection: 'content',
    ctaSection: 'cta',
    faqSection: 'faq',
    valueCardsSection: 'valueCards',
    locationsSection: 'locations',
    contactSection: 'contact',
  }

  // Resolves any Sanity image asset references within a section to plain CDN
  // URL strings, so section components never need to know about Sanity.
  function transformSection(section: any) {
    const type = sectionTypeMap[section._type]
    if (!type) return null
    const { _type, _key, ...rest } = section
    const out: any = { type, ...rest }

    if (type === 'hero') {
      out.image = urlFor(rest.image)
      out.secondaryImage = urlFor(rest.secondaryImage)
    }
    if (type === 'content') {
      out.image = urlFor(rest.image)
    }
    if (type === 'valueCards' && Array.isArray(rest.cards)) {
      out.cards = rest.cards.map((c: any) => ({ ...c, image: urlFor(c.image) }))
    }

    return out
  }

  function transformPageData(doc: any) {
    return {
      title: doc.title,
      name: doc.name,
      city: doc.city,
      description: doc.description,
      keywords: doc.keywords,
      sections: (doc.sections || []).map(transformSection).filter(Boolean),
      legalSections: doc.legalSections,
    }
  }

  const docs = await sanityClient.fetch(`*[_type == "page"]`)
  const paths: { params: { slug: string | undefined }, props: { pageData: any } }[] = []

  for (const doc of docs) {
    const slug = doc.slug?.current
    const pageData = transformPageData(doc)

    if (slug === 'index') {
      paths.push({ params: { slug: undefined }, props: { pageData } })
    } else {
      paths.push({ params: { slug }, props: { pageData } })
    }
  }

  return paths
}

const { pageData } = Astro.props
const sections = pageData.sections || []

const pageTitle = pageData.title || pageData.name
const isHomepage = Astro.url.pathname === '/'

// Get hero image for preloading (LCP optimization)
const heroSection = sections.find((s: any) => s.type === 'hero')
const heroImage = heroSection?.image

const slugParam = Astro.params.slug as string | undefined
const pageSchemas = buildPageSchemas(pageData, slugParam, Astro.url.pathname)
---

<BaseLayout
  title={pageTitle}
  description={pageData.description}
  keywords={pageData.keywords}
  preloadImage={heroImage}
  pageSchemas={pageSchemas}
>
  {sections.map((section: any) => {
    const { type, ...props } = section
    
    if (type === 'hero') {
      return isHomepage 
        ? <HeroHomeStatic {...props} />
        : <HeroPage {...props} />
    }
    
    if (type === 'features') return <FeaturesSection {...props} />
    if (type === 'content') return <ContentSection {...props} />
    if (type === 'cta') return <CTASection {...props} />
    if (type === 'faq') return <FAQSection {...props} />
    if (type === 'valueCards') return <ValueCardsSection {...props} />
    if (type === 'locations') return <LocationsSection {...props} />
    if (type === 'contact') return <ContactSection {...props} />
    
    return null
  })}
  
  {/* Legal pages with legalSections */}
  {pageData.legalSections && (
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 max-w-4xl">
        {pageData.legalSections.map((section: any) => (
          <div class="mb-8">
            <h2 class="text-xl font-semibold mb-4 text-gray-900">{section.title}</h2>
            {section.content && <p class="text-gray-600 mb-4" set:html={section.content} />}
            {section.items && (
              <ul class="list-disc list-inside text-gray-600 space-y-2 ml-4">
                {section.items.map((item: string) => <li set:html={item} />)}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
